# ============================================
# Stock Quant Trading Platform - Environment Variables
# ============================================
# Copy this file to .env and adjust values as needed.

# Backend settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./database/stock_quant.db

# Frontend settings
NEXT_PUBLIC_API_URL=http://localhost:8000

# Data settings
# Default data provider: "yfinance" (free, no API key needed)
DATA_PROVIDER=yfinance

# Optional: Alpha Vantage API key (for future use)
# ALPHA_VANTAGE_API_KEY=your_key_here

# Optional: Polygon.io API key (for future use)
# POLYGON_API_KEY=your_key_here

# Paper trading initial capital (USD)
PAPER_TRADING_INITIAL_CAPITAL=100000.0

# Risk management defaults
MAX_POSITION_SIZE_PCT=10.0
MAX_CONCURRENT_POSITIONS=10
DEFAULT_STOP_LOSS_PCT=5.0
DEFAULT_TAKE_PROFIT_PCT=15.0

# TODO: Future live trading integration
# BROKER_API_KEY=
# BROKER_API_SECRET=
# BROKER_SANDBOX=true
# WARNING: Live trading should ONLY be enabled after thorough testing.
# This platform is for EDUCATION and RESEARCH only.
